# Clé API-Football (api-football.com -> dashboard -> API Key)
API_FOOTBALL_KEY=

# Clé API Anthropic pour la couche d'analyse IA (console.anthropic.com)
# Optionnelle : sans elle, /api/predict fonctionne quand même, juste sans
# le champ "aiAnalysis" dans la réponse.
ANTHROPIC_API_KEY=

# Modèle à utiliser pour l'analyse (optionnel, défaut : claude-sonnet-5)
# Mets claude-haiku-4-5-20251001 pour réduire les coûts si tu appelles ça
# sur beaucoup de matchs.
AI_MODEL=

# Upstash Redis (mêmes identifiants que sur ARIA, ou une nouvelle base)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret pour protéger l'endpoint cron (chaîne aléatoire de ton choix)
CRON_SECRET=
